# ─── VIT VTOP A&D Portal Automation — Environment Variables Template ──────────
# Copy this file to .env and fill in your actual credentials.
# NEVER commit your .env file containing real passwords/credentials to git.

# ── VTOP Credentials ──────────────────────────────────────────────────────────
VTOP_USERNAME=your_vtop_username_here       # Your VTOP username
VTOP_PASSWORD=your_vtop_password_here       # Your VTOP password

# ── Gmail (For OTP extraction during Course Modification) ─────────────────────
GMAIL_ADDRESS=your_email@gmail.com          # Your Gmail email address
GMAIL_APP_PASSWORD=abcd efgh ijkl mnop      # Gmail App Password (16 characters, no spaces required)

# ── Portal Settings ───────────────────────────────────────────────────────────
BASE_URL=https://vtopreg.vit.ac.in/tablet/  # Base tablet URL of VTOP Registration Portal

# ── Browser Settings ──────────────────────────────────────────────────────────
CHROME_PATH=/usr/bin/google-chrome          # Path to Google Chrome executable
HEADLESS=false                              # Set to true to run Playwright in background
MONITOR_DELAY_SECONDS=30                    # Loop refresh sleep duration in seconds

COURSES_TO_MONITOR='[{"category": "DE", "keyword": "Cyber Security", "page": 2, "action": "register", "target_faculty": "", "target_slot": "1"}, {"category": "View/Modify", "keyword": "Software Industrialization", "page": 1, "action": "modify", "target_faculty": "PRABHU J", "target_slot": "1"}]'


# ── WhatsApp Notifications (Twilio) ───────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+14155238886              # Your Twilio Sandbox WhatsApp number
MY_PHONE_NUMBER=+919080014281               # Recipient WhatsApp phone number

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=seats.db                            # SQLite database filename

# ── Captcha Debug ─────────────────────────────────────────────────────────────
CAPTCHA_SAMPLES_DIR=captcha_samples         # Folder to dump captured CAPTCHAs for debugging

# ── Auto Registration / Modification ──────────────────────────────────────────
REGISTER=false                              # Set to true to enable automated 1-click registration (global fallback)
MODIFY=false                                # Set to true to enable automated 1-click modification (global fallback)
REGISTER_COURSES=[]                         # List of course keywords (JSON or comma-separated) to enable register mode for
MODIFY_COURSES=["software industrialization"] # List of course keywords to enable modify mode for
CHOSEN_FACULTY=""                           # Faculty name keyword (case-insensitive substring) to target
CHOSEN_SLOT=""                              # Slot name keyword (case-insensitive substring) to target
print_scrapper_data_in_terminal=false       # Set to true to print status of scraped slots directly to terminal


